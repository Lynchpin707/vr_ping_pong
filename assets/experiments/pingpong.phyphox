<phyphox xmlns="https://phyphox.org/xml" xmlns:editor="https://phyphox.org/xml/editor" version="1.19">
  <title>Ping Pong</title>
  <category>VR Experiments</category>
  <icon format="base64"></icon>
  <data-containers>
    <container size="0">gyrX</container>
    <container size="0">gyrY</container>
    <container size="0">gyrZ</container>
    <container size="0">linX</container>
    <container size="0">linY</container>
    <container size="0">linZ</container>
  </data-containers>
  <input>
    <sensor type="gyroscope" rate="0">
      <output component="x">gyrX</output>
      <output component="y">gyrY</output>
      <output component="z">gyrZ</output>
    </sensor>
    <sensor type="linear_acceleration" rate="0">
      <output component="x">linX</output>
      <output component="y">linY</output>
      <output component="z">linZ</output>
    </sensor>
  </input>
  <views>
    <view label="Data Stream">
      <value label="gyrX" unit="rad/s">
        <input>gyrX</input>
      </value>
      <value label="gyrY" unit="rad/s">
        <input>gyrY</input>
      </value>
      <value label="gyrZ" unit="rad/s">
        <input>gyrZ</input>
      </value>
      <value label="linX" unit="m/s">
        <input>linX</input>
      </value>
      <value label="linY" unit="m/s">
        <input>linY</input>
      </value>
      <value label="linZ" unit="m/s">
        <input>linZ</input>
      </value>
    </view>
  </views>
</phyphox>